{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/check-spdx.py",
            "timeout": 30,
            "statusMessage": "Checking SPDX header"
          }
        ]
      }
    ]
  }
}
