    <!-- Onboarding: unrestricted background/battery opt-in (#49) -->
    <string name="onboarding_battery_title">Get mail the instant it arrives</string>
    <string name="onboarding_battery_body">LibreMail keeps a lightweight connection open to deliver mail the moment it lands. Android\'s battery optimization can pause or close that connection, so messages may show up late — or only when you open the app.</string>
    <string name="onboarding_battery_guidance">On the next screen, open Battery and choose “Unrestricted”.</string>
    <string name="onboarding_battery_take_me">Take me there</string>
    <string name="onboarding_battery_not_now">Not now</string>
    <string name="onboarding_battery_done_title">You\'re all set</string>
    <string name="onboarding_battery_done_body">Background usage is unrestricted — new mail will arrive instantly.</string>
    <string name="onboarding_battery_continue">Continue to inbox</string>

    <!-- Onboarding: optional contacts-access opt-in for recipient autocomplete (#127, #128) -->
    <string name="onboarding_contacts_title">Suggest recipients as you type</string>
    <string name="onboarding_contacts_body">Allow access to your contacts and LibreMail will suggest matching names and email addresses while you compose. This happens entirely on your device — your contacts are never uploaded or shared. It\'s optional; you can skip it and enter addresses yourself.</string>
    <string name="onboarding_contacts_rationale">LibreMail needs the Contacts permission to suggest recipients. It\'s used only for on-device autocomplete — nothing is uploaded.</string>
    <string name="onboarding_contacts_allow">Allow contacts access</string>
    <string name="onboarding_contacts_not_now">Not now</string>
    <string name="onboarding_contacts_done_title">Autocomplete is on</string>
    <string name="onboarding_contacts_done_body">LibreMail will suggest recipients from your contacts as you compose — all on this device.</string>
    <string name="onboarding_contacts_continue">Continue</string>

